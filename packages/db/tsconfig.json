{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "outDir": "dist",
    "rootDir": "src",

    "composite": true,              // ✅ required for monorepo
    "declaration": true,            // ✅ useful for other packages

    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]               // ✅ fixes process/global errors
  },
  "include": ["src"]
}