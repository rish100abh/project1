{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "outDir": "dist",
    "rootDir": "src",

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],

    "baseUrl": ".",
    "paths": {
      "db": ["../packages/db/dist"]
    },

    "ignoreDeprecations": "6.0"   
  },
  "include": ["src"]
}