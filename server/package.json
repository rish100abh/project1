{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,js --exec tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:prod": "npm run prisma:generate && npm run prisma:migrate:deploy && node dist/index.js",
    "prisma:generate": "prisma generate --schema=../packages/db/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=../packages/db/prisma/schema.prisma"
  },
  "dependencies": {
    "db": "file:../packages/db",
    "@prisma/client": "6.19.3",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "nodemon": "^3.1.10",
    "prisma": "6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}